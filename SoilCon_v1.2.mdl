{UTF-8}
aep=
	1
	~	
	~		|

DESIRED FUNDS=
	100
	~	
	~		|

funds max switch=
	IF THEN ELSE(DEF SWITCH=1, 
	IF THEN ELSE( Cum def>Total rates tax, 1,0),
	IF THEN ELSE(DESIRED FUNDS>Total rates tax, 1, 0))
	~	Dmnl
	~		|

general rate=
	IF THEN ELSE(funds max switch=1,
	IF THEN ELSE(aep>RATE AEP,
	((REG RATE*ent change[DReg1]*ENT SHARE)*rate change)
	*RATES SWITCH, 0), 0)
	~	$M/yr
	~	IF THEN ELSE(DELAY RATE=1,
		IF THEN ELSE(aep>0.5,
		IF THEN ELSE(Property balance rates CHZ>0, 
		(((REGIONAL RATE*enterprise change[DReg1]+DISTRICT RATE*enterprise \
		change[DReg1])*ENT SHARE)*rate increase)
		*RATES SWITCH, 0), 0), 0)
	|

Inflationrt=
	1.03
	~	pcnt
	~		|

Builtcapital[Ind1,DRegions]=
	100
	~	$M
	~		|

Prop bal rates CHZ=
	1
	~	
	~		|

tot rates funds[DRegions]=
	100
	~	
	~		|

hhld rate=
	IF THEN ELSE(funds max switch=1,
	IF THEN ELSE(aep>RATE AEP,
	(((REG RATE*hhld change[DReg1]*REG BASE)*HHLD SHARE)*rate change
	)*RATES SWITCH, 0), 0)
	~	$M/yr
	~		|

Cum def=
	1
	~	
	~		|

DELTA TIME=
	1
	~	
	~		|

DEF SWITCH=
	1
	~	
	~		|

POP[DRegions]=
	1
	~	
	~		|

INI PROP=
	0.1
	~	
	~		|

realgdp=
	1
	~	
	~		|

RATES SWITCH=
	1
	~	
	~		|

REG BASE=
	70608
	~	Count
	~	Sum off all councils. http://www.ratepayersreport.nz/2018_report
	|

AVG HHLD SIZE=
	2.7
	~	
	~	http://archive.stats.govt.nz/Census/2013-census/profile-and-summary-reports\
		/qstats-families-households/households.aspx
	|

Governments:
	CentralG,LocalG
	~	
	~		|

Retreat rates funds[DReg1]= INTEG (
	SUM(rates tax[DReg1,Governments!,Industries!])-tot rates funds[DReg1],
		0) ~~|
Retreat rates funds[DReg2]= INTEG (
	SUM(rates tax[DReg2,Governments!,Industries!]),
		0)
	~	$M
	~		|

rates tax[DReg1,LocalG,Industries]=
	(Tot targeted rate[Industries]+Tot general rate[Industries]+Tot hhld rate[Ind1])*funds max switch\
		 ~~|
rates tax[DReg2,LocalG,Industries]=
	0 ~~|
rates tax[DReg1,CentralG,Industries]=
	0 ~~|
rates tax[DReg2,CentralG,Industries]=
	0
	~	$M/yr
	~		|

Cap balance  = A FUNCTION OF( -INI CAP) ~~|
Cap balance= INTEG (
	(cap risk+SUM(damages[Industries!])+Public insure claims[DReg1])*market adjustment*dt prop\
		,
		INI CAP*dt prop)
	~	$
	~		|

hhld change[DReg1]=
	((POP[DReg1]-INI POP[DReg1])/INI POP[DReg1])/AVG HHLD SIZE+1 ~~|
hhld change[DReg2]=
	((POP[DReg2]-INI POP[DReg2])/INI POP[DReg2])/AVG HHLD SIZE+1
	~	
	~		|

CHZ hhld share[DReg1]=
	(INI PROP/REG BASE)*hhld change[DReg1] ~~|
CHZ hhld share[DReg2]=
	0
	~	
	~		|

CHZ IND RATES SHARE[Industries]:INTERPOLATE::=
	GET XLS DATA('?scenariodata', 'Rates' , '10' , 'B11' )
	~	
	~		|

Cum rates funds[DRegions]= INTEG (
	+tot rates funds[DRegions],
		0)
	~	$M
	~		|

DELAY RATE= DELAY FIXED (
	1, 13, 0)
	~	
	~		|

DIST BASE=
	30642+24988
	~	
	~	HDC 30642 and NCC 24988 ratepayer count. \
		http://www.ratepayersreport.nz/2018_report
	|

INI CAP=
	1.57281e+09
	~	$
	~	Vulnerable assets within the 1% AEP coastal inundation  by 2120  (CDEM)
	|

rates retreat=
	SMOOTH3(IF THEN ELSE( targeted rate>0,prop per year, 0), 40)
	~	Count
	~	Smooth is the delayed reaction of the decision to retreat.
	|

INI POP[DReg1]=
	152900 ~~|
INI POP[DReg2]=
	4.071e+06
	~	
	~		|

INI REALGDP=
	171400
	~	$M
	~		|

prop per year=
	RETREAT LOOKUP(prop remit)
	~	
	~		|

prop reduce=
	rates retreat
	~	Count
	~		|

ENT[DRegions]:INTERPOLATE::=
	GET XLS DATA('?basedata', 'POPULATION' , '1' , 'B15' )
	~	Count
	~	Enterprises from Business Directory data ANZSIC 2016 & StatsNZ 2019
	|

ent change[DRegions]=
	SMOOTH(ENT[DRegions]*(((realgdp-INI REALGDP)/INI REALGDP)+1), 5)
	~	
	~		|

ENT SHARE=
	0.75
	~	
	~	Percentage of rates paid by enterprise
	|

rate change=
	IF THEN ELSE(SUM(Tot general rate[Industries!])+SUM(Tot targeted rate[Industries!])+\
		SUM(Tot hhld rate[Industries!])<DESIRED FUNDS
	, (1+Inflationrt
	)+PRUDENT CHANGE, 0)
	~	Percent
	~		|

INVESTMENT ALLOCATION[Ind1]=
	0.034 ~~|
INVESTMENT ALLOCATION[Ind2]=
	0.006 ~~|
INVESTMENT ALLOCATION[Ind3]=
	0.192 ~~|
INVESTMENT ALLOCATION[Ind4]=
	0.161 ~~|
INVESTMENT ALLOCATION[Ind5]=
	0.004 ~~|
INVESTMENT ALLOCATION[Ind6]=
	0.026 ~~|
INVESTMENT ALLOCATION[Ind7]=
	0.303 ~~|
INVESTMENT ALLOCATION[Ind8]=
	0.058 ~~|
INVESTMENT ALLOCATION[Ind9]=
	0.213 ~~|
INVESTMENT ALLOCATION[IND10]=
	0.002
	~	Percent
	~	Percentage of industry affected leading to investment allocation
	|

Tot hhld rate[Ind1]= INTEG (
	0,
		0) ~~|
Tot hhld rate[Ind2]= INTEG (
	0,
		0) ~~|
Tot hhld rate[Ind3]= INTEG (
	0,
		0) ~~|
Tot hhld rate[Ind4]= INTEG (
	0,
		0) ~~|
Tot hhld rate[Ind5]= INTEG (
	0,
		0) ~~|
Tot hhld rate[Ind6]= INTEG (
	0,
		0) ~~|
Tot hhld rate[Ind7]= INTEG (
	0,
		0) ~~|
Tot hhld rate[Ind8]= INTEG (
	0,
		0) ~~|
Tot hhld rate[Ind9]= INTEG (
	hhld rate,
		0) ~~|
Tot hhld rate[IND10]= INTEG (
	0,
		0)
	~	$M
	~		|

Total rates tax= INTEG (
	SUM(rates tax[DReg1,Governments!,Industries!]),
		0)
	~	$M/yr
	~		|

RETREAT LOOKUP(
	[(0,0)-(0.01,2451)],(3.0581e-05,129),(0.000733945,139.75),(0.00186544,193.5),(0.00296636\
		,354.75),(0.00397554,559),(0.00510703,870.75),(0.00565749,1150.25),(0.00614679,1472.75\
		),(0.0064526,1709.25),(0.00681957,1988.75),(0.00740061,2171.5),(0.0082263,2322),(0.00911315\
		,2386.5),(0.00993884,2429.5))
	~	Dmnl
	~		|

REG RATE=
	0.00015
	~	
	~	TAG $15 regional rate under defence scenario.
		$150 under regional rate scenario
	|

ind share built cap[Ind3]=
	0 ~~|
ind share built cap[Ind1]=
	Builtcapital[Ind1,DReg1]/(SUM(Builtcapital[Industries!,DReg1])-Builtcapital[Ind3,DReg1\
		]-Builtcapital[Ind9,DReg1]) ~~|
ind share built cap[Ind2]=
	Builtcapital[Ind2,DReg1]/(SUM(Builtcapital[Industries!,DReg1])-Builtcapital[Ind3,DReg1\
		]-Builtcapital[Ind9,DReg1]) ~~|
ind share built cap[Ind4]=
	Builtcapital[Ind4,DReg1]/(SUM(Builtcapital[Industries!,DReg1])-Builtcapital[Ind3,DReg1\
		]-Builtcapital[Ind9,DReg1]) ~~|
ind share built cap[Ind5]=
	Builtcapital[Ind5,DReg1]/(SUM(Builtcapital[Industries!,DReg1])-Builtcapital[Ind3,DReg1\
		]-Builtcapital[Ind9,DReg1]) ~~|
ind share built cap[Ind6]=
	Builtcapital[Ind6,DReg1]/(SUM(Builtcapital[Industries!,DReg1])-Builtcapital[Ind3,DReg1\
		]-Builtcapital[Ind9,DReg1]) ~~|
ind share built cap[Ind7]=
	Builtcapital[Ind7,DReg1]/(SUM(Builtcapital[Industries!,DReg1])-Builtcapital[Ind3,DReg1\
		]-Builtcapital[Ind9,DReg1]) ~~|
ind share built cap[Ind8]=
	Builtcapital[Ind8,DReg1]/(SUM(Builtcapital[Industries!,DReg1])-Builtcapital[Ind3,DReg1\
		]-Builtcapital[Ind9,DReg1]) ~~|
ind share built cap[Ind9]=
	0 ~~|
ind share built cap[IND10]=
	Builtcapital[IND10,DReg1]/(SUM(Builtcapital[Industries!,DReg1])-Builtcapital[Ind3,DReg1\
		]-Builtcapital[Ind9,DReg1])
	~	
	~	less government and household
	|

RATE AEP=
	1.2
	~	Percent
	~		|

tot rates tax[DRegions,Governments]=
	SUM(rates tax[DRegions,Governments,Industries!])
	~	
	~		|

Tot general rate[Industries]= INTEG (
	general rate*ind share built cap[Industries],
		0)
	~	$M
	~		|

Tot targeted rate[Industries]= INTEG (
	targeted rate*CHZ IND RATES SHARE[Industries],
		0)
	~	$M
	~		|

PRUDENT CHANGE=
	0.05
	~	Percent
	~	Prudential change
	|

HHLD SHARE=
	0.25
	~	
	~	Percentage of rates paid by enterprise
	|

prop remit=
	SMOOTH(IF THEN ELSE(Prop bal rates CHZ>0, (DESIRED FUNDS/Prop bal rates CHZ)*rate change\
		*DELTA TIME, 0), 5)
	~	$M/yr
	~	Property remittance
	|

targeted rate=
	IF THEN ELSE(funds max switch=1, 
	IF THEN ELSE(aep>RATE AEP,(Prop bal rates CHZ*prop remit)*RATES SWITCH, 0), 0)
	~	$M/yr
	~	0.85 = percentage from targeted rate (WRC \
		https://www.waikatoregion.govt.nz/council/rates/targeted-rates/)
	|

ECS INI=
	30
	~	$M
	~		|

TREATED LAND=
	18924
	~	
	~		|

DRAW DOWN START=
	DELAY FIXED(1, 19, 0)
	~	
	~		|

DRAW DOWN STOP=
	DELAY FIXED( 0, 20, 1)
	~	$M
	~		|

tot treatment land=
	SUM(treatment land[LUC!])
	~	
	~		|

ECS Funding= INTEG (
	IF THEN ELSE( DRAW DOWN START=1,ECS INI, 0)-ECS Funding,
		0)
	~	
	~		|

land mgmt working cap=
	ECS Funding-SUM(Treatment cost[Intervention!])
	~	
	~		|

treatment rate[Baseline]=
	0 ~~|
treatment rate[PoplarPoles]=
	SMOOTH3( (POLE PRICE*POLE DENSITY*tot treatment land)*INTERVENE START*INTERVENE STOP
	, 5) ~~|
treatment rate[ExoticForest]=
	SMOOTH3( EXOTIC PRICE*EXOTIC DENSITY*tot treatment land*INTERVENE START*INTERVENE STOP
	, 5) ~~|
treatment rate[Native]=
	SMOOTH3( (NATIVE PLANTING COST*tot treatment land+fencing)*INTERVENE START*INTERVENE STOP
	, 5)
	~	$M/yr
	~		|

treatment land[LUC]=
	(INI SLIP LAND-TREATED LAND)*INTERVENE START*TREATMENT LUC SHARE[LUC]
	~	
	~		|

Native Reduction= INTEG (
	SMOOTH3(EXP(marginal reduction n)-TIME STEP, 20),
		0)
	~	
	~		|

fencing=
	DEER FENCING COST*FENCE LENGTH
	~	$M
	~		|

marginal reduction n=
	DELAY FIXED( (1-Native Reduction)*REDUCTION FACTOR N, 24, 0)
	~	
	~		|

REDUCTION FACTOR N=
	1.9
	~	pcnt
	~		|

slip rate[PoplarPoles]=
	SMOOTH(IF THEN ELSE(INTERVENE START=0, soil weight conversion-Slip Erosion[Baseline]\
		 ,((soil weight conversion-soil weight conversion
	*
	(Pole Reduction/100))-Slip Erosion[PoplarPoles])), 4) ~~|
slip rate[ExoticForest]=
	SMOOTH(IF THEN ELSE(INTERVENE START=0, soil weight conversion-Slip Erosion[Baseline]\
		 ,((soil weight conversion-soil weight conversion
*(Forest Reduction
	/100))-Slip Erosion[ExoticForest])), 4) ~~|
slip rate[Baseline]=
	SMOOTH(soil weight conversion-Slip Erosion[Baseline], 4) ~~|
slip rate[Native]=
	SMOOTH(IF THEN ELSE(INTERVENE START=0, soil weight conversion-Slip Erosion[Baseline]\
		 ,((soil weight conversion-soil weight conversion
	*
	(Native Reduction/100))-Slip Erosion[Native])), 4)
	~	t/yr
	~	SMOOTH of 4 to reflect Interdecal Pacific Oscillation.
	|

FENCE LENGTH=
	6544
	~	m
	~	Taken from FME workbench.
	|

NATIVE PLANTING COST=
	0.011228
	~	
	~	Taken from 'Retiring Farmland into Native using the Tīmata Method' Our \
		Land Our Water slides. 2023 value from 'Timata Forestry Grade 3 m spacing'.
	|

DEER FENCING COST=
	4.5e-05
	~	$M
	~	Netting = $482 per 100 m. Posts = $53 each. Gates = $539. Labour = $10/m. \
		Or $45/m according to Jess.
	|

marginal reduction f= DELAY FIXED (
	 ((1-Forest Reduction)*REDUCTION FACTOR F)-Logging delta, 24, 0)
	~	Dmnl
	~		|

Forest Reduction= INTEG (
	SMOOTH3(EXP(marginal reduction f)-TIME STEP, 6)-Logging delta,
		0)
	~	pcnt
	~		|

Logging delta= INTEG (
	(log weight conversion-Logging delta)/1e+07,
		0)
	~	pcnt
	~		|

slip prone land=
	INI SLIP LAND*slip likelihood
	~	ha
	~		|

POLE DENSITY=
	300
	~	n/ha
	~	https://www.hbrc.govt.nz/assets/Document-Library/Information-Sheets/Land/LM\
		CT15.pdf
	|

POLE PRICE=
	3e-05
	~	$M
	~	Anecdotal. $15 for pole and $15 to plant
	|

total revenue[Baseline]=
	stock revenue[Baseline]-treatment rate[Baseline] ~~|
total revenue[PoplarPoles]=
	stock revenue[PoplarPoles]-treatment rate[PoplarPoles] ~~|
total revenue[ExoticForest]=
	stock revenue[ExoticForest]+log revenue-treatment rate[ExoticForest]
	~	$M/yr
	~		~	:SUPPLEMENTARY 
	|

EXOTIC DENSITY=
	300
	~	n/ha
	~	https://www.hbrc.govt.nz/assets/Document-Library/Information-Sheets/Land/LM\
		CT15.pdf
	|

EXOTIC PRICE=
	1.555e-05
	~	$M
	~	https://awapuni.co.nz/commercial-radiata-pine.
		Plus same rate to plant as pole.
	|

Tot log revenue= INTEG (
	log revenue,
		0)
	~	$M
	~		~	:SUPPLEMENTARY 
	|

Treatment cost[Intervention]= INTEG (
	treatment rate[Intervention]/TIME STEP,
		0)
	~	$M/yr
	~		~	:SUPPLEMENTARY 
	|

log revenue=
	SMOOTH3( (log weight conversion*LOG UNIT PRICE-harvest cost), 10)
	~	$M/yr
	~	https://www.mfat.govt.nz/assets/Trade-General/Trade-Market-reports/STORM-An\
		alysis-Regional-Summaries-Hawkes-Bay-28-September-2020-PDF.pdf
	|

HARVEST DELAY STOP= DELAY FIXED (
	0, 55, 1)
	~	
	~		|

RECOVERABLE VOLUME=
	300
	~	
	~	Total recoverable volume tonnes/hectare (James Powrie). Initial value = \
		700.
	|

harvest cost=
	SMOOTH3(SUM(treatment land[LUC!])*STUMPAGE*HARVEST DELAY START*HARVEST DELAY STOP, 5\
		)
	~	$M
	~		|

STUMPAGE=
	0.015395
	~	$M/ha
	~	Taken from James Powrie's Harvest Cost Model V1. Net Stumpage per hectare.
	|

LOG UNIT PRICE=
	0.000135
	~	$M/t
	~		|

HARVEST DELAY START= DELAY FIXED (
	1, 54, 0)
	~	
	~	30 years till maturity
	|

retired land[LUC]=
	IF THEN ELSE(INTERVENE START=1, (INI SLIP LAND/15)*(LAND RETIREMENT SHARE*100)*TREATMENT LUC SHARE\
		[LUC], 0)
	~	
	~		|

log weight conversion=
	SMOOTH3(SUM(treatment land[LUC!])*RECOVERABLE VOLUME*HARVEST DELAY START*HARVEST DELAY STOP\
		, 5)
	~	t
	~	https://www.forestenterprises.co.nz/why-invest-in-forestry/forestry-in-new-\
		zealand/
	|

stock revenue[Intervention]=
	total stock units[Intervention]*STOCK UNIT PRICE
	~	$M/yr
	~		|

carrying capacity I[LUC]=
	SMOOTH3( (INI CARRYING CAPACITY[LUC]*intervention land[LUC]*productivity*farm surplus\
		)-Intervention Stock Units[LUC], 2)
	~	
	~	5 year average
	|

STOCK UNIT PRICE=
	0.000116
	~	$M
	~	Taken from 'Retiring Farmland into Native using the Tīmata Method' Our \
		Land Our Water slides. 2023 value from 'Marginal steep land profitability'.
	|

surplus ratio=
	1.28
	~	
	~	Taken from Awapapa Financial summary, Awapapa vs District Average = \
		$609/$476 = 1.28
	|

farm surplus=
	SMOOTH3(IF THEN ELSE( PROD DELAY STOP=0, surplus ratio, 1), 20)
	~	
	~	Smoothed over 20 years so that the sum of 20 + the 12 years of lower \
		productivity add up to a poplar at full maturity.
	|

Slip Erosion[Intervention]= INTEG (
	slip rate[Intervention]/TIME STEP,
		0)
	~	t/yr
	~	On average, an estimated 7.2 million tonnes of soil across Hawke’s Bay \
		are currently lost through erosion processes each year. Regionally, \
		landslide is the predominant cause of erosion, transporting about 5 \
		million tonnes of fine sediment into waterways in Hawke’s Bay each year \
		- SOE Report 2018-21
	|

intervention land[LUC]=
	IF THEN ELSE( INTERVENE START=0, baseline land[LUC],treatment land[LUC]+retired land\
		[LUC]-(slip prone land*TREATMENT LUC SHARE
	[LUC])+baseline land[LUC]-treatment land[LUC]-retired land[LUC])
	~	ha
	~		|

land rate=
	Tot Baseline Land-slip prone land-diverse rt
	~	ha/yr
	~	LAND RETIREMENT SHARE*RETIRE DELAY START*Tot Baseline Land*RETIRE DELAY \
		STOP
	|

soil weight conversion=
	slip prone land*CONSTANT*SOIL BULK DENSITY
	~	
	~		|

deposition rate[Intervention]=
	Slip Erosion[Intervention]*SEDIMENT DELIVERY RATIO-Sediment Deposition[Intervention]
	~	t/yr
	~		|

SEDIMENT DELIVERY RATIO=
	0.25
	~	pcnt
	~	Sediment delivery ratios range from 0.21 to 0.29,Spiekermann 2022.
	|

Intervention Reduction Erosion[PoplarPoles]= INTEG (
	IF THEN ELSE( Slip Erosion[Baseline]=0, 0,(Slip Erosion[PoplarPoles]-Slip Erosion[Baseline\
		])/Slip Erosion[PoplarPoles]),
		0) ~~|
Intervention Reduction Erosion[ExoticForest]= INTEG (
	IF THEN ELSE( Slip Erosion[Baseline]=0, 0,(Slip Erosion[ExoticForest]-Slip Erosion[Baseline\
		])/Slip Erosion[ExoticForest]),
		0) ~~|
Intervention Reduction Erosion[Baseline]= INTEG (
	Slip Erosion[Baseline]-Slip Erosion[Baseline],
		0) ~~|
Intervention Reduction Erosion[Native]= INTEG (
	IF THEN ELSE( Slip Erosion[Baseline]=0, 0,(Slip Erosion[Native]-Slip Erosion[Baseline\
		])/Slip Erosion[Native]),
		0)
	~	pcnt
	~		~	:SUPPLEMENTARY 
	|

SOIL BULK DENSITY=
	1.4
	~	t
	~	we compute sediment yields for the landslide triggering event, assuming \
		soil bulk density is 1.4 t m􀀀 3 and an average scar depth of 1 m \
		(Crozier, 1996). Spiekermann 2022.
	|

CONSTANT=
	350
	~	Dmnl
	~	Constant to calibrate model with SOE report.
	|

marginal reduction p= DELAY FIXED (
	 (1-Pole Reduction)*REDUCTION FACTOR P, 24, 0)
	~	Dmnl
	~		|

Sediment Deposition[Intervention]= INTEG (
	(deposition rate[Intervention]-Sediment Deposition[Intervention])/TIME STEP,
		0)
	~	t/yr
	~	Proportion of erosion.
	|

mean deposition=
	RANDOM NORMAL( 1, 334, 32.74, 70.08, 12345)
	~	m3/ha
	~	Taken from FMESummaryStats.xlsx sc_m_depos
	~	:SUPPLEMENTARY 
	|

Intervention Reduction Deposition[PoplarPoles]= INTEG (
	IF THEN ELSE( Sediment Deposition[Baseline]=0, 0,(Sediment Deposition[PoplarPoles]-Sediment Deposition\
		[Baseline])/Sediment Deposition[PoplarPoles]),
		0) ~~|
Intervention Reduction Deposition[ExoticForest]= INTEG (
	IF THEN ELSE( Sediment Deposition[Baseline]=0, 0,(Sediment Deposition[ExoticForest]-\
		Sediment Deposition[Baseline])/Sediment Deposition[ExoticForest]),
		0) ~~|
Intervention Reduction Deposition[Baseline]= INTEG (
	Sediment Deposition[Baseline]-Sediment Deposition[Baseline],
		0)
	~	pcnt
	~		~	:SUPPLEMENTARY 
	|

BASELINE LUC SHARE[LUC1]=
	0.011 ~~|
BASELINE LUC SHARE[LUC2]=
	0.016 ~~|
BASELINE LUC SHARE[LUC3]=
	0.132 ~~|
BASELINE LUC SHARE[LUC4]=
	0.099 ~~|
BASELINE LUC SHARE[LUC5]=
	0.029 ~~|
BASELINE LUC SHARE[LUC6]=
	0.523 ~~|
BASELINE LUC SHARE[LUC7]=
	0.161 ~~|
BASELINE LUC SHARE[LUC8]=
	0.029
	~	pcnt
	~	Taken from FME output FME_LUCStatsWorking.xlsx.
	|

TREATMENT LUC SHARE[LUC1]=
	0 ~~|
TREATMENT LUC SHARE[LUC2]=
	0 ~~|
TREATMENT LUC SHARE[LUC3]=
	0 ~~|
TREATMENT LUC SHARE[LUC4]=
	0 ~~|
TREATMENT LUC SHARE[LUC5]=
	0.05 ~~|
TREATMENT LUC SHARE[LUC6]=
	0.05 ~~|
TREATMENT LUC SHARE[LUC7]=
	0.2 ~~|
TREATMENT LUC SHARE[LUC8]=
	0.8
	~	
	~		|

baseline land[LUC]=
	Tot Baseline Land*BASELINE LUC SHARE[LUC]
	~	ha
	~		|

carrying capacity R[LUC]=
	SMOOTH3( INI CARRYING CAPACITY[LUC]*baseline land[LUC]-Baseline Stock Units[LUC], 2)
	~	
	~	5 year average
	|

LUC:
	LUC1,LUC2,LUC3,LUC4,LUC5,LUC6,LUC7,LUC8
	~	
	~		|

ANTECEDENT RAINFALL:INTERPOLATE::=
	GET XLS DATA('?basedata', 'L4L' , '1' , 'B2' )
	~	mm
	~		~	:SUPPLEMENTARY 
	|

Baseline Stock Units[LUC]= INTEG (
	carrying capacity R[LUC]-Baseline Stock Units[LUC],
		INI STOCK UNITS[LUC])
	~	n
	~		|

DIVERSE FACTOR=
	-0.022
	~	Dmnl
	~	-0.012
	|

diverse rt=
	DIVERSE FACTOR*Tot Baseline Land
	~	ha/yr
	~		|

Diversification= INTEG (
	SQRT(diverse rt*diverse rt),
		0)
	~	ha
	~		~	:SUPPLEMENTARY 
	|

Pole Reduction= INTEG (
	SMOOTH3(EXP(marginal reduction p)-TIME STEP, 6),
		0)
	~	pcnt
	~		|

total stock units[Baseline]=
	SUM(Baseline Stock Units[LUC!]) ~~|
total stock units[PoplarPoles]=
	SUM(Intervention Stock Units[LUC!]) ~~|
total stock units[ExoticForest]=
	SUM(Baseline Stock Units[LUC!])-SUM(treatment land[LUC!]) ~~|
total stock units[Native]=
	SUM(Intervention Stock Units[LUC!])
	~	n
	~	Agricultural production statistics year to June 2022: Total sheep = \
		2775748. Total beef = 453919. Total = 3229667.
	|

Intervention Stock Units[LUC]= INTEG (
	+carrying capacity I[LUC]-Intervention Stock Units[LUC],
		INI STOCK UNITS[LUC])
	~	n
	~		|

INI SLIP LAND=
	90943
	~	ha
	~	90943 taken from FME investigation of farmland for Warwick. This covers \
		lancon 4 - 7.
	|

Tot Baseline Land= INTEG (
	Tot Baseline Land-land rate,
		INI TOTAL LAND)
	~	ha
	~		|

slip likelihood=
	RANDOM WEIBULL(0, 1, 0.8, 0.15 , 0.3,NOISE SEED )
	~	
	~		|

NOISE SEED=
	GET TIME VALUE(2,0,10)
	~	
	~		|

POLE SHARE=
	0.4
	~	pcnt
	~		~	:SUPPLEMENTARY 
	|

REDUCTION FACTOR P=
	1.35
	~	pcnt
	~		|

FORESTRY SHARE=
	0.6
	~	pcnt
	~		~	:SUPPLEMENTARY 
	|

REDUCTION FACTOR F=
	1.44
	~	pcnt
	~		|

Intervention:
	PoplarPoles,ExoticForest,Baseline,Native
	~	
	~		|

productivity=
	SMOOTH(IF THEN ELSE( PROD DELAY START=0:OR:PROD DELAY STOP=0, 1, (1-DIMINISHING RETURN\
		)), 2)
	~	
	~		|

land loss=
	INI TOTAL LAND-Tot Baseline Land
	~	ha
	~		~	:SUPPLEMENTARY 
	|

PROD DELAY START= DELAY FIXED (
	1, 24, 0)
	~	
	~		|

PROD DELAY STOP= DELAY FIXED (
	0, 36, 1)
	~	
	~		|

DIMINISHING RETURN=
	0.1
	~	pcnt
	~		|

INI STOCK UNITS[LUC]=
	6
	~	
	~	https://www.mpi.govt.nz/dmsdocument/4221-Farm-Monitoring-Report-2012-Pastoral-Monitor\
		ing-Hawkes-BayWairarapa-sheep-and-beef. 
		https://www.mpi.govt.nz/dmsdocument/5671-farm-monitoring-report-2009-pastoral-monitor\
		ing-hawkes-baywairarapa-hill-country-sheep-and-beef
		Assuming Hawke's Bay is half of Hawke's Bay/Wairarapa count divided evenly \
		across the LUCs.
	|

