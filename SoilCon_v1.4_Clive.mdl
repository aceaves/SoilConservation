Delta Stock Revenue[Intervention,Catchment]=MAX(
	  1,
	  100 * ZIDZ(
	    stock revenue total[Intervention,Catchment] - stock revenue prev[Intervention,Catchment\
		],
	    stock revenue prev[Intervention,Catchment]
