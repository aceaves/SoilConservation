CONSTANT=1
	~	Dmnl
	~	Constant to calibrate model with SOE report. Was 2600
	|

marginal reduction p= DELAY FIXED (
	 (1-Pole Reduction)*REDUCTION FACTOR P, 24, 0)
	~	Dmnl
