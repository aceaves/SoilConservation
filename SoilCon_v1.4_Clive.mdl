DRAW DOWN START=
	DELAY FIXED(1, 19, 0)
	~	
	~		|

Native Reduction= INTEG (SMOOTH3(EXP(marginal reduction n), 20),
		0)
	~	pcnt
	~		|

marginal reduction n=
	DELAY FIXED( (1-Native Reduction)*REDUCTION FACTOR N, 24, 0)
	~	
	~		|

REDUCTION FACTOR N=3.8
	~	pcnt
	~	Started with 1.9
		Use 5.2 to get to 90% reduction.
