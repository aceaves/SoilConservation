	~		|

Pole Reduction= INTEG (SMOOTH3(EXP(marginal reduction p), 12),
		0)
	~	pcnt
	~		|

NOISE SEED=
	GET TIME VALUE(2,0,10)
	~	
	~		|

REDUCTION FACTOR P=3.4
	~	pcnt
	~	Started with 1.35
		4.8 gets to 70% in Pole Reduction
	|

Intervention:PolesConventional,PolesBestPractice,Baseline
