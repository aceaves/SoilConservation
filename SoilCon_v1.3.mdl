{UTF-8}
Diverse Adjustment Time=-0.8
	~	Dmnl
	~		|

land loss=PastoralFarmland-Tot Baseline Land
	~	ha
	~		|

PastoralFarmland:=GET XLS DATA('?basedata', 'FARMAREA' , '1' , 'B2' )
	~	ha
	~		|

Tot Baseline Land= INTEG (-land rate,
		PastoralFarmland)
	~	ha
	~		|

baseline land[LUC]=Tot Baseline Land*BASELINE LUC SHARE[LUC]
	~	ha
	~		~	:SUPPLEMENTARY 
	|

diverse rt=Tot Baseline Land / Diverse Adjustment Time
	~	ha/yr
	~		|

land rate=SMOOTH ( MIN( Tot Baseline Land / TIME STEP , MAX( 0, slip prone land[Baseline\
		] ) + MAX( 0, diverse rt ) ), 3)
	~	ha/yr
	~	LAND RETIREMENT SHARE*RETIRE DELAY START*Tot Baseline Land*RETIRE DELAY STOP
		
		(Tot Baseline Land/TIME STEP)-slip prone land[Baseline]-diverse rt
	|

slip prone land[Baseline]=INI SLIP LAND*slip likelihood ~~|
slip prone land[PoplarPoles]=INI SLIP LAND*slip likelihood-Planted Land ~~|
slip prone land[Native]=INI SLIP LAND*slip likelihood-retired land
	~	ha/yr
	~		|

INI RDP[Industries]:INTERPOLATE::=
	GET XLS DATA('?basedata', 'RDP' , '1' , 'B2' )
	~	$M/yr
	~		|

tot treated land=
	INI TREATED LAND+Planted Land+retired land
	~	
	~		|

soil weight conversion[Intervention]=
	slip prone land[Intervention]*CONSTANT*SOIL BULK DENSITY
	~	t/yr
	~		|

planting rt=
	IF THEN ELSE(Planted Land < (INI SLIP LAND-retired land), INI PLANTING RT*INTERVENE START\
		+Deaths+end of life replacements, 0)
	~	ha/yr
	~	Aim for 900 ha per year (from initial conversation).
		2024-25 = 600 ha
		2025-26 = 800 ha
		2026-27 = 900 ha
	|

slip rate[PoplarPoles]=IF THEN ELSE(INTERVENE START=0, soil weight conversion[PoplarPoles\
		]-Slip Erosion[PoplarPoles] ,((soil weight conversion[PoplarPoles]-soil weight conversion\
		[PoplarPoles]
	*(Pole Reduction/100))-Slip Erosion[PoplarPoles])) ~~|
slip rate[Baseline]=soil weight conversion[Baseline]-Slip Erosion[Baseline] ~~|
slip rate[Native]=IF THEN ELSE(INTERVENE START=0, soil weight conversion[Native]-Slip Erosion\
		[Native] ,((soil weight conversion[Native]-soil weight conversion[Native]
	*(Native Reduction/100))-Slip Erosion[Native]))
	~	t/yr
	~	SMOOTH of 4 to reflect Interdecal Pacific Oscillation.
	|

end of life replacements=
	SMOOTH3( Planted Land*REPLACEMENT RATIO, 40)
	~	
	~		~	:SUPPLEMENTARY 
	|

tot rates funds=SMOOTH(IF THEN ELSE(Trig count>=PAY TRIG,Retreat rates funds,0),4)
	~	Dmnl
	~		|

sig WL=
	MAX( (catchment hydro), High Water )
	~	m
	~	Logic statement to set the significant water level at high tide or \
		greater, thereby removing low values.
	|

storm trigger=
	IF THEN ELSE(INIT DONE = 0, 0, RANDOM NORMAL(0, 1, 0.5, FREQUENCY, NOISE SEED 2))
	~	Dmnl
	~	Random probability distribution to enable a significant storm event to occur.
		Original: RANDOM NORMAL(0, 1, 0.5,FREQUENCY, NOISE SEED 0)
	|

INIT DONE=
	IF THEN ELSE(Time < 1, 0, 1)
	~	
	~		|

NOISE SEED 2=
	GET TIME VALUE(2,0,10)
	~	
	~		|

IND LAND SHARE CHZ[IND01]=
	0.002 ~~|
IND LAND SHARE CHZ[IND02]=
	0.011 ~~|
IND LAND SHARE CHZ[IND03]=
